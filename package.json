{
  "name": "next-web-app-starter-for-yeyu",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "pages:dev": "pnpm run pages:build && wrangler pages dev",
    "pages:build": "pnpx @cloudflare/next-on-pages",
    "pages:deploy": "pnpm run pages:build && wrangler pages deploy",
    "typecheck": "tsc",
    "lint": "biome check --max-diagnostics=100 .",
    "lint:fix": "biome check --max-diagnostics=100 --write .",
    "prepare": "husky",
    "commit": "git-cz",
    "qwer": "git-cz"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/postcss": "^4.2.2",
    "@tanstack/react-query": "^5.99.2",
    "@tanstack/react-query-devtools": "^5.96.2",
    "class-variance-authority": "^0.7.1",
    "ky": "^2.0.0",
    "lucide-react": "^1.7.0",
    "next": "16.2.3",
    "next-themes": "^0.4.6",
    "postcss": "^8.5.9",
    "react": "^19.2.5",
    "react-dom": "^19.2.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "commitizen": "^4.3.1",
    "cz-git": "^1.12.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.2"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-git"
    }
  },
  "packageManager": "pnpm@9.13.2"
}
